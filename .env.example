PROJECT_NAME=MyApp

# Application
NODE_ENV=development
PORT=3001
APP_VERSION=1.0.0

# Frontend URL
FRONTEND_URL=http://localhost:5173

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/{{DB_NAME}}?schema=public
DB_POOL_SIZE=10

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-change-this-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Email Service
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Security
SESSION_SECRET=your-session-secret-change-this-in-production
CSRF_SECRET=your-csrf-secret-change-this-in-production
# HEALTH_API_KEY=your-health-api-key-min-16-chars
# COOKIE_DOMAIN=.yourdomain.com

# Observability (optional — enables OpenTelemetry tracing when set)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Cloudinary (Media Uploads - Optional)
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
