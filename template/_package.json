{
  "name": "{{PROJECT_NAME}}",
  "version": "1.0.0",
  "description": "{{PROJECT_NAME}} Backend API",
  "main": "dist/src/app.js",
  "scripts": {
    "dev": "nodemon src/app.ts",
    "build": "npx tsc --project tsconfig.json",
    "start": "node dist/src/app.js",
    "start:migrate": "npx prisma migrate deploy && npm run start",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:integration:watch": "vitest --project integration",
    "test:all": "vitest run",
    "docker:test:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "docker:test:down": "docker compose -f docker-compose.test.yml down -v",
    "k6:smoke": "k6 run k6/smoke.js",
    "k6:load": "k6 run k6/load.js",
    "k6:rate-limit": "k6 run k6/rate-limit.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prisma:generate": "npx prisma generate && node -e \"require('fs').writeFileSync('generated/prisma/index.ts','// Barrel re-export (Prisma 7 has no index.ts)\\nexport * from \\\"./client\\\";\\n')\"",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "create:superadmin": "ts-node prisma/createSuperAdmin.ts",
    "docker:build": "docker build -t {{PROJECT_NAME_LOWER}}-backend .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f app",
    "prepare": "husky install || true"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation-express": "^0.62.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.0.0",
    "cloudinary": "^2.8.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^3.0.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.3.1",
    "form-data": "^4.0.5",
    "handlebars": "^4.7.8",
    "helmet": "^8.0.0",
    "isomorphic-dompurify": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "nodemailer": "^8.0.5",
    "pg": "^8.16.3",
    "prisma": "^7.0.0",
    "prom-client": "^15.1.3",
    "redis": "^5.9.0",
    "resend": "^6.1.0",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "overrides": {
    "minimatch": ">=9.0.7"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
